# Public domain (must point to your Hetzner server IP)
DOMAIN=app.example.com
APP_URL=https://app.example.com

# Main app Postgres
APP_DB_NAME=openclaw_paywall
APP_DB_USER=openclaw
APP_DB_PASSWORD=change-me

# Mission Control Postgres
MC_DB_NAME=mission_control
MC_DB_USER=mission_control
MC_DB_PASSWORD=change-me-too

# Required app secrets
SESSION_SECRET=replace-with-64-char-random-secret
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
VITE_CLERK_PUBLISHABLE_KEY=pk_live_xxx

# Gateway auth mode: use "none" for seamless embedded UI, or "token" for hardened setups.
OPENCLAW_GATEWAY_AUTH_MODE=none
OPENCLAW_GATEWAY_TOKEN=

# Optional for Mission Control local-token mode fallback
MISSION_CONTROL_TOKEN=replace-with-long-random-token

# Deploy webhook security (required if you use /api/deploy)
DEPLOY_WEBHOOK_SECRET=replace-with-long-random-secret
DEPLOY_GIT_REMOTE=origin
DEPLOY_GIT_BRANCH=master
